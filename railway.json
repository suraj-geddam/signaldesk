{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "watchPatterns": [
      "app/**",
      "Dockerfile",
      "init.sql",
      "pyproject.toml",
      "railway.json",
      "uv.lock"
    ]
  },
  "deploy": {
    "preDeployCommand": "python -m app.bootstrap",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
