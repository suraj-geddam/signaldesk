{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "watchPatterns": [
      "src/**",
      "Caddyfile",
      "Dockerfile",
      "index.html",
      "package-lock.json",
      "package.json",
      "railway.json",
      "vite.config.ts"
    ]
  },
  "deploy": {
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
