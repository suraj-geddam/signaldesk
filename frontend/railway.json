{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "watchPatterns": [
      "/frontend/src/**",
      "/frontend/Caddyfile",
      "/frontend/Dockerfile",
      "/frontend/index.html",
      "/frontend/package-lock.json",
      "/frontend/package.json",
      "/frontend/railway.json",
      "/frontend/vite.config.ts"
    ]
  },
  "deploy": {
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
